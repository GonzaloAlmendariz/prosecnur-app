#!/usr/bin/env bash
set -euo pipefail

APP_ROOT="$(cd "$(dirname "$0")/../../.." && pwd)"
BUNDLED_INTERNALS="$(cd "$(dirname "$0")/../Resources/Internals" && pwd)"
EXTERNAL_INTERNALS="$APP_ROOT/Internals"
INTERNALS="$BUNDLED_INTERNALS"
RUNTIME_ROOT="$HOME/Library/Application Support/Prosecnur"
RUNTIME_DESKTOP="$RUNTIME_ROOT/desktop-runtime"
LOG_DIR="$HOME/Library/Logs/Prosecnur"
LOG_FILE="$LOG_DIR/desktop.log"

mkdir -p "$LOG_DIR"
mkdir -p "$RUNTIME_ROOT"

if [ ! -d "$INTERNALS" ] && [ -d "$EXTERNAL_INTERNALS" ]; then
  INTERNALS="$EXTERNAL_INTERNALS"
fi

# Finder abre las .app con un PATH mínimo. Agregamos rutas comunes de
# Homebrew, R.framework, Node y pnpm para que funcione con doble click.
export PATH="/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:/usr/local/sbin:/Library/Frameworks/R.framework/Resources/bin:$HOME/Library/pnpm:$HOME/.local/share/pnpm:$PATH"

fail_dialog() {
  local message="$1"
  /usr/bin/osascript -e "display dialog \"$message\" buttons {\"OK\"} default button \"OK\" with title \"Prosecnur\"" >/dev/null 2>&1 || true
}

if ! command -v pnpm >/dev/null 2>&1; then
  if command -v corepack >/dev/null 2>&1; then
    corepack enable >/dev/null 2>&1 || true
  fi
fi

if ! command -v pnpm >/dev/null 2>&1; then
  fail_dialog "No se encontró pnpm. Instala Node.js 20 o superior y pnpm para usar Prosecnur en modo escritorio. Si ya lo instalaste, abre Prosecnur nuevamente."
  exit 1
fi

if ! command -v Rscript >/dev/null 2>&1; then
  fail_dialog "No se encontró Rscript. Instala R 4.1 o superior para abrir Prosecnur."
  exit 1
fi

if ! command -v rsync >/dev/null 2>&1; then
  fail_dialog "No se encontró rsync. Verifica tu instalación de macOS e intenta nuevamente."
  exit 1
fi

mkdir -p "$RUNTIME_DESKTOP"
rsync -a --delete --exclude ".DS_Store" --exclude "node_modules" "$INTERNALS/desktop/" "$RUNTIME_DESKTOP/" >> "$LOG_FILE" 2>&1

if [ ! -d "$RUNTIME_DESKTOP/node_modules/electron" ]; then
  {
    echo "[$(date)] Instalando dependencias de escritorio..."
    pnpm --dir "$RUNTIME_DESKTOP" install
  } >> "$LOG_FILE" 2>&1 || {
    fail_dialog "No se pudieron instalar las dependencias de escritorio. Revisa $LOG_FILE."
    exit 1
  }
fi

cd "$RUNTIME_DESKTOP"
export PULSO_APP_ROOT="$INTERNALS"
exec pnpm --dir "$RUNTIME_DESKTOP" start >> "$LOG_FILE" 2>&1
