# macOS
.DS_Store

# R
.Rhistory
.RData
.Rproj.user/
*.Rproj
Rplots.pdf
renv/library/
renv/local/
renv/staging/
.Rprofile.local

# Node / frontend
node_modules/
frontend/dist/
frontend/.vite/
frontend/tsconfig.tsbuildinfo
*.log

# Local app packages. Usamos `dist.nosync/` cuando el repo vive en
# iCloud Drive (el sufijo .nosync hace que iCloud lo ignore y evita
# copias fantasma "Prosecnur 2/3/4..." por conflicto de sync).
# Dejamos `dist/` también para backward-compat con builds viejos.
dist/
dist.nosync/

# Frontend build outputs (regenerados en build):
#   - api/inst/www/        : bundle del Electron (con code splitting)
#   - api/inst/standalone/ : bundle único usado por /api/dashboard/export
api/inst/www/*
!api/inst/www/.gitkeep
api/inst/standalone/

# Editor
.vscode/
.idea/

# Tests
/tests/e2e/results/
/tests/e2e/playwright-report/

# Audit outputs (generados por scripts/ast_corpus_audit.R etc.)
api/outputs/

# Backups puntuales (ej. fixes manuales de data con .bak_edad_fix)
*.bak_edad_fix
*.bak_*

# Datos del analista (no van al repo)
insumos/

# Build artifacts del paquete R
prosecnurapp_*.tar.gz

# Staging de runtime mac generado por packaging/macos/build-dmg.sh
# (se regenera por arch en cada build, pesa ~300MB con paquetes R + R.pkg).
packaging/macos/r-mac-runtime/

# .icns generado a partir de packaging/windows/brand/icon.svg.
packaging/macos/build-resources/icon.icns
packaging/macos/build-resources/icon.iconset/

# Backups puntuales del .pulso (limpieza manual)
*.pulso.pre-cleanup.bak
